{
  "expo": {
    "name": "理智",
    "slug": "sanity",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#1a1a1a",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sanity.app"
    },
    "android": {
      "package": "com.sanity.app",
      "adaptiveIcon": {
        "backgroundColor": "#1a1a1a",
        "foregroundImage": "./assets/icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": []
    },
    "plugins": [
      "expo-secure-store",
      "expo-file-system"
    ]
  }
}
