{
  "name": "@wisadel/desktop",
  "version": "0.2.4",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --configLoader runner",
    "dev:electron": "concurrently \"vite --configLoader runner\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc -p tsconfig.json && vite build --configLoader runner && tsc -p electron/tsconfig.json",
    "package:win": "npm run build && electron-builder --win nsis --publish never",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p electron/tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@wisadel/contracts": "*",
    "electron-updater": "^6.6.2",
    "lucide-react": "^0.468.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zustand": "^5.0.7"
  },
  "devDependencies": {
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@types/node": "^24.1.0",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.0",
    "electron": "^37.2.4",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.3",
    "vite": "^7.0.6",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.4"
  },
  "build": {
    "appId": "com.leamonage.wisadel",
    "productName": "Wisadel",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "resources/**/*",
      "package.json"
    ],
    "win": {
      "target": ["nsis"],
      "icon": "resources/Wisadel.ico",
      "artifactName": "Wisadel-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Wisadel",
      "installerHeader": "resources/installer-header.bmp",
      "installerSidebar": "resources/installer-sidebar.bmp",
      "uninstallerSidebar": "resources/uninstaller-sidebar.bmp"
    },
    "publish": {
      "provider": "github",
      "owner": "LeamonAge",
      "repo": "Wisadel"
    }
  }
}
