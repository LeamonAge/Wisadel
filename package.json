{
  "name": "wisadel",
  "version": "0.1.11",
  "main": "main.js",
  "dependencies": {
    "electron-updater": "^6.6.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.4",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.4",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "html-webpack-plugin": "^5.6.7",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.6.2",
    "typescript": "~6.0.3",
    "wait-on": "^8.0.5",
    "webpack": "^5.108.4",
    "webpack-cli": "^6.0.1"
  },
  "scripts": {
    "dev": "concurrently \"cross-env BROWSER=none expo start --web\" \"wait-on http://localhost:19006 && electron .\"",
    "build:renderer": "webpack --mode production",
    "build": "npm run build:renderer && electron-builder --win --config electron-builder.yml",
    "release": "npm run build && electron-builder --win --config electron-builder.yml --publish always",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web"
  },
  "build": {
    "appId": "com.sanity.app",
    "productName": "Wisadel",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "dist/**/*",
      "assets/**/*",
      "!node_modules/**/*",
      "node_modules/electron-updater/**/*",
      "node_modules/semver/**/*",
      "node_modules/builder-util-runtime/**/*",
      "node_modules/js-yaml/**/*",
      "node_modules/argparse/**/*",
      "node_modules/lodash.isequal/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/Wisadel.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Wisadel",
      "artifactName": "Wisadel-${version}-${arch}.${ext}",
      "installerHeader": "assets/installer-header.bmp",
      "installerSidebar": "assets/installer-sidebar.bmp",
      "uninstallerSidebar": "assets/uninstaller-sidebar.bmp"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "LeamonAge",
        "repo": "Wisadel",
        "private": false
      }
    ]
  },
  "private": true
}
